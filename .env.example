# --- Supabase (required for live mode) -------------------------------------
# Create a free project at https://supabase.com, apply supabase/migrations/*.sql
# (in order) in the SQL editor, then copy these from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- EDR ingest (bring-your-own-EDR) ----------------------------------------
# Long random secret; senders POST /api/edr/ingest with `Authorization: Bearer <token>`.
# Generate one:  openssl rand -hex 32        (unset = endpoint disabled, 404)
AGENTGUARD_INGEST_TOKEN=

# --- AI risk panel (optional — pick ONE provider) ---------------------------
# Cloud (Anthropic):
#ANTHROPIC_API_KEY=
# Fully on-prem (Ollama / LM Studio / vLLM — tool args never leave your machines):
#AGENTGUARD_AI_PROVIDER=local
#AGENTGUARD_AI_BASE_URL=http://host.docker.internal:11434/v1
#AGENTGUARD_AI_MODEL=gpt-oss:20b
#AGENTGUARD_AI_API_KEY=ollama

# --- Optional ----------------------------------------------------------------
# Absolute URL of this dashboard (used in social-share metadata).
#NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Lock down /signup after you created your accounts.
#AGENTGUARD_DISABLE_SIGNUP=true
# Where the demo's GitHub button points.
#NEXT_PUBLIC_GITHUB_URL=https://github.com/merveealpay
# Contact links shown on the demo hero (defaults: the AgentGuard maintainer's).
#NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
#NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
